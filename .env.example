# Sentinel AI — Environment Configuration
# Copy this file to .env and fill in your values.

# ─── API Keys ───
GROQ_API_KEY=
HINDSIGHT_API_KEY=

# ─── Feature Flags ───
HINDSIGHT_ENABLED=true

# ─── Paths ───
POLICY_FILE=policies/hipaa.json
AUDIT_LOG_PATH=audit.log

# ─── Logging ───
LOG_LEVEL=INFO

# ─── Agent Config ───
AGENT_NAME=Prime
PROJECT_NAME=Sentinel AI

# ─── Server ───
HOST=0.0.0.0
PORT=8000
