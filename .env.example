# Sentinel AI — Environment Configuration
# Copy this file to .env and fill in your values.

# ─── API Keys ───
GROQ_API_KEY=
HINDSIGHT_API_KEY=

# ─── Hindsight Configuration ───
# For Hindsight Cloud: https://api.hindsight.vectorize.io
# For self-hosted: http://localhost:8888
HINDSIGHT_BASE_URL=https://api.hindsight.vectorize.io
HINDSIGHT_BANK_ID=
HINDSIGHT_ENABLED=true

# ─── Ollama (optional fallback) ───
OLLAMA_BASE_URL=http://localhost:11434/v1

# ─── Paths ───
POLICY_FILE=policies/hipaa.json
AUDIT_LOG_PATH=audit.log

# ─── Logging ───
LOG_LEVEL=INFO

# ─── Agent Config ───
AGENT_NAME=Prime
PROJECT_NAME=Sentinel AI

# ─── Server ───
HOST=0.0.0.0
PORT=8000
